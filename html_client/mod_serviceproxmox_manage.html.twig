{% if order.status == 'active' %}
    {% set vm = client.serviceproxmox_vm_get({"order_id": order.id}) %}
    {% set proxmox_service = client.serviceproxmox_get_proxmox_service({"order_id": order.id}) %}
    {% set ssh_key_data = client.serviceproxmox_ssh_key_get({}) %}

    {# ── VM Info ───────────────────────────────────────────────────────────── #}
    <div class="row mb-4">
        <div class="col-md-6">
            <table class="table table-bordered">
                <tr><th>{{ 'Status' | trans }}</th><td><span class="badge badge-{{ vm.status == 'running' ? 'success' : 'secondary' }}">{{ vm.status }}</span></td></tr>
                <tr><th>{{ 'IP Address' | trans }}</th><td>{{ proxmox_service.ipv4 ?? '—' }}</td></tr>
                <tr><th>{{ 'Hostname' | trans }}</th><td>{{ proxmox_service.hostname ?? '—' }}</td></tr>
                <tr><th>{{ 'Username' | trans }}</th><td>root</td></tr>
                <tr><th>{{ 'VMID' | trans }}</th><td>{{ proxmox_service.vmid ?? '—' }}</td></tr>
            </table>
        </div>
    </div>

    {# ── VM Controls ───────────────────────────────────────────────────────── #}
    <div class="mb-4">
        <a class="btn btn-success api-link me-1"
           href="{{ 'api/client/serviceproxmox/vm_manage'|link({'order_id': order.id, 'method': 'start', 'CSRFToken': CSRFToken}) }}"
           data-api-confirm="{{ 'Are you sure?' | trans }}"
           data-api-msg="{{ 'VM starting. Reload the page in a few moments.' | trans }}">
            {{ 'Start' | trans }}
        </a>
        <a class="btn btn-danger api-link me-1"
           href="{{ 'api/client/serviceproxmox/vm_manage'|link({'order_id': order.id, 'method': 'shutdown', 'CSRFToken': CSRFToken}) }}"
           data-api-confirm="{{ 'Are you sure?' | trans }}"
           data-api-msg="{{ 'VM shutting down. Reload the page in a few moments.' | trans }}">
            {{ 'Shutdown' | trans }}
        </a>
        <a class="btn btn-warning api-link me-1"
           href="{{ 'api/client/serviceproxmox/vm_manage'|link({'order_id': order.id, 'method': 'reboot', 'CSRFToken': CSRFToken}) }}"
           data-api-confirm="{{ 'Are you sure?' | trans }}"
           data-api-msg="{{ 'VM rebooting. Reload the page in a few moments.' | trans }}">
            {{ 'Reboot' | trans }}
        </a>
        <a class="btn btn-outline-danger api-link"
           href="{{ 'api/client/serviceproxmox/vm_reinstall'|link({'order_id': order.id, 'CSRFToken': CSRFToken}) }}"
           data-api-confirm="{{ 'This will ERASE all data on your VM and reinstall from scratch. Are you absolutely sure?' | trans }}"
           data-api-msg="{{ 'Reinstall started. This may take a few minutes.' | trans }}">
            {{ 'Reinstall' | trans }}
        </a>
    </div>

    {# ── Console ──────────────────────────────────────────────────────────── #}
    <div class="mb-4">
        <h4>{{ 'Console' | trans }}</h4>
        {% if vm.status == 'running' %}
            <button id="btn-console" class="btn btn-secondary" onclick="openConsole({{ order.id }}, '{{ CSRFToken }}')">
                {{ 'Open Console' | trans }}
            </button>
            <p class="text-muted small mt-1">{{ 'Opens the Proxmox noVNC console in a new tab. Requires network access to the Proxmox host.' | trans }}</p>
        {% else %}
            <p class="text-muted">{{ 'Start the VM to open a console.' | trans }}</p>
        {% endif %}
    </div>

    <script>
    function openConsole(orderId, csrfToken) {
        var btn = document.getElementById('btn-console');
        btn.disabled = true;
        btn.textContent = '{{ 'Loading…' | trans }}';

        fetch('{{ 'api/client/serviceproxmox/vm_console' | link }}', {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded'},
            body: 'order_id=' + orderId + '&CSRFToken=' + encodeURIComponent(csrfToken)
        })
        .then(r => r.json())
        .then(function(data) {
            if (data.result && data.result.url) {
                window.open(data.result.url, '_blank', 'noopener');
            } else {
                alert('{{ 'Could not obtain console URL. Is the VM running?' | trans }}');
            }
        })
        .catch(function() {
            alert('{{ 'Console request failed.' | trans }}');
        })
        .finally(function() {
            btn.disabled = false;
            btn.textContent = '{{ 'Open Console' | trans }}';
        });
    }
    </script>

{% endif %}

{# ── SSH Key Management (always visible, not order-specific) ──────────────── #}
<div class="card mt-4">
    <div class="card-header">
        <h5 class="mb-0">{{ 'SSH Public Key' | trans }}</h5>
    </div>
    <div class="card-body">
        <p class="text-muted small">
            {{ 'Your SSH key is injected into new VPS instances at provisioning time. Updating the key here does not affect already-running servers.' | trans }}
        </p>

        {% if ssh_key_data.ssh_key %}
            <div class="alert alert-success d-flex align-items-start gap-2">
                <div class="flex-grow-1">
                    <strong>{{ 'Key on file:' | trans }}</strong><br>
                    <code class="small text-break">
                        {{ ssh_key_data.ssh_key | slice(0, 60) }}…
                        {% set parts = ssh_key_data.ssh_key | split(' ') %}
                        {% if parts | length >= 3 %} {{ parts | last }}{% endif %}
                    </code>
                </div>
                <a class="btn btn-sm btn-outline-danger api-link flex-shrink-0"
                   href="{{ 'api/client/serviceproxmox/ssh_key_delete'|link({'CSRFToken': CSRFToken}) }}"
                   data-api-confirm="{{ 'Remove your SSH key?' | trans }}"
                   data-api-msg="{{ 'SSH key removed.' | trans }}">
                    {{ 'Remove' | trans }}
                </a>
            </div>
        {% endif %}

        <form method="POST" action="{{ 'api/client/serviceproxmox/ssh_key_save' | link }}" class="api-form" data-api-msg="{{ 'SSH key saved.' | trans }}">
            <input type="hidden" name="CSRFToken" value="{{ CSRFToken }}">
            <div class="mb-3">
                <label for="ssh_key" class="form-label">{{ (ssh_key_data.ssh_key ? 'Replace SSH key' : 'Add SSH key') | trans }}</label>
                <textarea class="form-control font-monospace"
                          id="ssh_key"
                          name="ssh_key"
                          rows="3"
                          placeholder="ssh-ed25519 AAAA... user@host"
                          required></textarea>
                <div class="form-text">{{ 'Supported types: ssh-rsa, ssh-ed25519, ecdsa-sha2-*' | trans }}</div>
            </div>
            <button type="submit" class="btn btn-primary">{{ 'Save key' | trans }}</button>
        </form>
    </div>
</div>
